<?xml version="1.0" encoding="utf-8"?>
<ViewFlipper xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/viewFlipper"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <RelativeLayout
        android:id="@+id/splashLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">
        <androidx.cardview.widget.CardView
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_centerInParent="true"
            app:cardCornerRadius="60dp"
            app:cardElevation="20dp"
            app:cardBackgroundColor="@android:color/transparent">
            <ImageView
                android:id="@+id/imgLogoTeam"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/logoteam"
                android:scaleType="centerCrop" />
            <ImageView
                android:id="@+id/imgLogoMe"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/logome"
                android:scaleType="centerCrop"
                android:visibility="gone" />
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/homeLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main_neon"> 
        
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_alignParentEnd="true"
            android:layout_margin="25dp"
            android:background="@drawable/circle_neon_btn"
            android:src="@drawable/ic_settings"
            android:padding="12dp"
            android:scaleType="fitCenter"
            app:tint="#00FFCC"
            android:elevation="10dp"/>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/logoapp"
                android:elevation="15dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEON TIC TAC TOE"
                android:textColor="#00FFCC"
                android:textSize="34sp"
                android:textStyle="bold"
                android:shadowColor="#00FFCC"
                android:shadowRadius="20"
                android:letterSpacing="0.05"/>

            <Button
                android:id="@+id/btnGameTicTacToe"
                android:layout_width="260dp"
                android:layout_height="70dp"
                android:layout_marginTop="50dp"
                android:text="PLAY NOW"
                android:backgroundTint="#00FFCC"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                app:cornerRadius="35dp"
                android:elevation="15dp"/>

            <Button
                android:id="@+id/btnExitApp"
                android:layout_width="200dp"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:text="EXIT GAME"
                android:backgroundTint="#1A1A1A"
                android:textColor="#FF4444"
                app:cornerRadius="30dp"
                android:elevation="5dp"/>
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:background="#0A0A0A"
        android:gravity="center_horizontal">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#00FFCC"
            android:textSize="28sp"
            android:textStyle="bold"/>
            
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333" android:layout_marginVertical="20dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#151515"
            android:layout_marginBottom="20dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="25dp"
                android:gravity="center">

                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/logome"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MohFahmiMc"
                    android:textColor="#00FFCC"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="15dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Android Developer"
                    android:textColor="#888"
                    android:textSize="16sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="25dp">

                    <ImageButton
                        android:id="@+id/btnGithub"
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:src="@drawable/ic_github"
                        android:background="@drawable/circle_neon_btn"
                        android:padding="14dp"
                        android:scaleType="fitCenter"
                        app:tint="#FFFFFF"
                        android:layout_marginEnd="20dp"/>

                    <ImageButton
                        android:id="@+id/btnWeb"
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:src="@drawable/ic_web"
                        android:background="@drawable/circle_neon_btn"
                        android:padding="14dp"
                        android:scaleType="fitCenter"
                        app:tint="#00FFCC"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnCloseSettings"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:text="BACK"
            android:backgroundTint="#00FFCC"
            android:textColor="#000000"
            android:textStyle="bold"
            app:cornerRadius="15dp"/>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#050505">

        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/neon_card_bg"
            android:orientation="vertical"
            android:padding="30dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PILIH MODE"
                android:textColor="#00FFCC"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="35dp"
                android:shadowColor="#00FFCC"
                android:shadowRadius="10"/>

            <Button
                android:id="@+id/btnModeRobot"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="VS ROBOT (AI)"
                android:backgroundTint="#007BFF"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="15dp"
                android:layout_marginBottom="18dp"/>

            <Button
                android:id="@+id/btnModeFriends"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="VS FRIENDS (LOCAL)"
                android:backgroundTint="#6F42C1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="15dp"/>
        </LinearLayout>
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#050505">

        <ImageView
            android:id="@+id/dustEffect"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/dust_particles"
            android:alpha="0.2"
            android:scaleType="centerCrop"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#111111"
            app:cardElevation="15dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:id="@+id/tvTurnStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giliran: P1"
                        android:textColor="#00FFCC"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                    <ImageButton
                        android:id="@+id/btnResetScore"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:src="@drawable/ic_refresh"
                        android:background="@android:color/transparent"
                        android:padding="5dp"
                        android:scaleType="fitCenter"
                        app:tint="#FF4444"/>
                </RelativeLayout>
                
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:alignmentMode="alignMargins">
                    <TextView android:id="@+id/score_p1" android:layout_columnWeight="1" android:text="P1: 0" android:textColor="#00FFCC" android:textSize="14sp" android:gravity="center" android:padding="4dp"/>
                    <TextView android:id="@+id/score_p2" android:layout_columnWeight="1" android:text="P2: 0" android:textColor="#FF4444" android:textSize="14sp" android:gravity="center" android:padding="4dp"/>
                    <TextView android:id="@+id/score_p3" android:layout_columnWeight="1" android:text="P3: 0" android:textColor="#FFBB33" android:textSize="14sp" android:gravity="center" android:padding="4dp"/>
                    <TextView android:id="@+id/score_p4" android:layout_columnWeight="1" android:text="P4: 0" android:textColor="#99CC00" android:textSize="14sp" android:gravity="center" android:padding="4dp"/>
                    <TextView android:id="@+id/score_p5" android:layout_columnWeight="1" android:text="P5: 0" android:textColor="#AA66CC" android:textSize="14sp" android:gravity="center" android:padding="4dp"/>
                    <TextView android:id="@+id/score_p6" android:layout_columnWeight="1" android:text="P6: 0" android:textColor="#33B5E5" android:textSize="14sp" android:gravity="center" android:padding="4dp"/>
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <GridLayout
            android:id="@+id/gameGrid"
            android:layout_width="340dp"
            android:layout_height="340dp"
            android:layout_centerInParent="true"
            android:columnCount="3"
            android:rowCount="3"
            android:padding="8dp"
            android:background="@drawable/grid_neon_border"
            android:elevation="10dp"/>

        <View
            android:id="@+id/hellOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_hell"
            android:visibility="gone"
            android:elevation="20dp"/>

        <Button
            android:id="@+id/btnExitGame"
            android:layout_width="180dp"
            android:layout_height="60dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="40dp"
            android:text="QUIT GAME"
            android:textStyle="bold"
            android:backgroundTint="#FF4444"
            app:cornerRadius="30dp"
            android:elevation="10dp"/>

        <RelativeLayout
            android:id="@+id/gameOverLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F2000000"
            android:gravity="center"
            android:visibility="gone"
            android:elevation="150dp">

            <LinearLayout
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                android:background="@drawable/neon_card_bg"
                android:orientation="vertical"
                android:padding="30dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERMAINAN BERAKHIR"
                    android:textColor="#FF4444"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:shadowColor="#FF4444"
                    android:shadowRadius="15"/>

                <TextView
                    android:id="@+id/tvWinnerResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pemain X Menang!"
                    android:textColor="#00FFCC"
                    android:textSize="20sp"
                    android:layout_marginTop="20dp"
                    android:textAlignment="center"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnPlayAgain"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="35dp"
                    android:text="MAIN LAGI"
                    android:backgroundTint="#00FFCC"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    app:cornerRadius="15dp"/>

                <Button
                    android:id="@+id/btnBackToMenu"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="10dp"
                    android:text="MENU UTAMA"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="15dp"/>
            </LinearLayout>
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/dialogPlayerCount"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F2000000"
            android:gravity="center"
            android:visibility="gone"
            android:elevation="150dp">

            <LinearLayout
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                android:background="@drawable/neon_card_bg"
                android:orientation="vertical"
                android:padding="30dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PILIH JUMLAH PEMAIN"
                    android:textColor="#00FFCC"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="30dp"/>

                <Button
                    android:id="@+id/btnOpt2"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:text="2 Players (3x3)"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#00FFCC"
                    android:layout_marginBottom="15dp"
                    app:cornerRadius="15dp"
                    android:textStyle="bold"
                    android:textAllCaps="false"/>

                <Button
                    android:id="@+id/btnOpt4"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:text="4 Players (6x6)"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#00FFCC"
                    android:layout_marginBottom="15dp"
                    app:cornerRadius="15dp"
                    android:textStyle="bold"
                    android:textAllCaps="false"/>

                <Button
                    android:id="@+id/btnOpt6"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:text="6 Players (10x10)"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#00FFCC"
                    app:cornerRadius="15dp"
                    android:textStyle="bold"
                    android:textAllCaps="false"/>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
</ViewFlipper>
