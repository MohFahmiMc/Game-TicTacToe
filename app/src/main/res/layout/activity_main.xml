<?xml version="1.0" encoding="utf-8"?>
<ViewFlipper xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/viewFlipper"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <RelativeLayout
        android:id="@+id/splashLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">
        <androidx.cardview.widget.CardView
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_centerInParent="true"
            app:cardCornerRadius="60dp"
            app:cardElevation="20dp"
            app:cardBackgroundColor="@android:color/transparent">
            <ImageView
                android:id="@+id/imgLogoTeam"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/logoteam"
                android:scaleType="centerCrop" />
            <ImageView
                android:id="@+id/imgLogoMe"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/logome"
                android:scaleType="centerCrop"
                android:visibility="gone" />
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/homeLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main_neon"> 
        
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentEnd="true"
            android:layout_margin="20dp"
            android:background="@drawable/circle_neon_btn"
            android:src="@drawable/ic_settings"
            app:tint="#00FFCC"/>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:src="@drawable/logoapp"
                android:elevation="15dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEON TIC TAC TOE"
                android:textColor="#00FFCC"
                android:textSize="32sp"
                android:textStyle="bold"
                android:shadowColor="#00FFCC"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="15"/>

            <Button
                android:id="@+id/btnGameTicTacToe"
                android:layout_width="260dp"
                android:layout_height="70dp"
                android:layout_marginTop="60dp"
                android:text="PLAY NOW"
                android:backgroundTint="#00FFCC"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                app:cornerRadius="35dp"
                android:elevation="12dp"/>

            <Button
                android:id="@+id/btnExitApp"
                android:layout_width="200dp"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:text="EXIT GAME"
                android:backgroundTint="#222222"
                android:textColor="#FF4444"
                app:cornerRadius="30dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:background="#0A0A0A">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#00FFCC"
            android:textSize="28sp"
            android:textStyle="bold"/>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333" android:layout_marginVertical="20dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dev: Mohfahmi"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>
        <Button
            android:id="@+id/btnCloseSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:text="BACK"
            android:backgroundTint="#00FFCC"
            android:textColor="#000000"/>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:gravity="center">

        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/neon_card_bg"> 
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SELECT MODE"
                android:textAlignment="center"
                android:textColor="#00FFCC"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp"/>

            <Button
                android:id="@+id/btnModeRobot"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="VS ROBOT (AI)"
                android:backgroundTint="#007BFF"
                app:cornerRadius="15dp"
                android:layout_marginBottom="15dp"/>

            <Button
                android:id="@+id/btnModeFriends"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="VS FRIENDS (LOCAL)"
                android:backgroundTint="#6F42C1"
                app:cornerRadius="15dp"/>
        </LinearLayout>
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#050505">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#111111"
            app:cardElevation="15dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:id="@+id/tvTurnStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giliran: P1"
                        android:textColor="#00FFCC"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <ImageButton
                        android:id="@+id/btnResetScore"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_alignParentEnd="true"
                        android:src="@drawable/ic_refresh"
                        android:background="@android:color/transparent"
                        app:tint="#FF4444"/>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">
                    <TextView android:id="@+id/score_p1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="P1: 0" android:textColor="#FFF" android:textSize="12sp" android:gravity="center"/>
                    <TextView android:id="@+id/score_p2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="P2: 0" android:textColor="#FFF" android:textSize="12sp" android:gravity="center"/>
                    <TextView android:id="@+id/score_p3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="P3: 0" android:textColor="#FFF" android:textSize="12sp" android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="5dp"
                    android:weightSum="3">
                    <TextView android:id="@+id/score_p4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="P4: 0" android:textColor="#FFF" android:textSize="12sp" android:gravity="center"/>
                    <TextView android:id="@+id/score_p5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="P5: 0" android:textColor="#FFF" android:textSize="12sp" android:gravity="center"/>
                    <TextView android:id="@+id/score_p6" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="P6: 0" android:textColor="#FFF" android:textSize="12sp" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <GridLayout
            android:id="@+id/gameGrid"
            android:layout_width="340dp"
            android:layout_height="340dp"
            android:layout_centerInParent="true"
            android:columnCount="10"
            android:rowCount="10"
            android:padding="2dp"
            android:background="@drawable/grid_neon_border"
            android:elevation="10dp"/>

        <Button
            android:id="@+id/btnExitGame"
            android:layout_width="180dp"
            android:layout_height="55dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="30dp"
            android:text="QUIT GAME"
            android:textStyle="bold"
            android:backgroundTint="#FF4444"
            app:cornerRadius="25dp"/>
    </RelativeLayout>
</ViewFlipper>
